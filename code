# ============================================================
# Clip all GOSIF files to Corn Belt using MemoryFile
# ============================================================

from pathlib import Path
import re
import pandas as pd
import rasterio
from rasterio.io import MemoryFile
from rasterio.windows import from_bounds

SIF_DIR = Path("/content/drive/MyDrive/Crop_Remote_Sensing_US/SIF")
OUT_DIR = Path("/content/drive/MyDrive/Crop_Remote_Sensing_US/_analysis_step2_fixSIF")
OUT_DIR.mkdir(parents=True, exist_ok=True)

ROI = {
    "left": -98.0,
    "bottom": 38.0,
    "right": -84.0,
    "top": 45.0
}

def parse_gosif_year_month(name):
    m = re.search(r'GOSIF_(20\d{2})\.M(0[1-9]|1[0-2])', name)
    if m:
        return int(m.group(1)), int(m.group(2))
    return None, None

def clip_tif_to_roi_memoryfile(in_fp, out_fp, roi_bounds):
    data = in_fp.read_bytes()

    with MemoryFile(data) as memfile:
        with memfile.open() as src:
            if str(src.crs) != "EPSG:4326":
                raise ValueError(f"{in_fp.name} CRS is {src.crs}, expected EPSG:4326")

            win = from_bounds(
                roi_bounds["left"], roi_bounds["bottom"],
                roi_bounds["right"], roi_bounds["top"],
                transform=src.transform
            ).round_offsets().round_lengths()

            out_data = src.read(window=win)
            out_transform = src.window_transform(win)

            profile = src.profile.copy()
            profile.update({
                "height": out_data.shape[1],
                "width": out_data.shape[2],
                "transform": out_transform
            })

            with rasterio.open(out_fp, "w", **profile) as dst:
                dst.write(out_data)

                if src.descriptions is not None:
                    for i, desc in enumerate(src.descriptions, start=1):
                        try:
                            dst.set_band_description(i, desc if desc is not None else "")
                        except:
                            pass

sif_files = sorted(SIF_DIR.glob("GOSIF_*.tif"))
print("GOSIF files found:", len(sif_files))

rows = []
for fp in sif_files:
    year, month = parse_gosif_year_month(fp.name)
    out_fp = SIF_DIR / f"{fp.stem}_CornBeltClip.tif"

    try:
        if not out_fp.exists():
            clip_tif_to_roi_memoryfile(fp, out_fp, ROI)
            status = "created"
        else:
            status = "exists"

        with rasterio.open(out_fp) as ds:
            rows.append({
                "source_file": fp.name,
                "clipped_file": out_fp.name,
                "year": year,
                "month": month,
                "status": status,
                "width": ds.width,
                "height": ds.height,
                "count": ds.count,
                "crs": str(ds.crs),
                "res_x": ds.res[0],
                "res_y": ds.res[1],
                "left": ds.bounds.left,
                "bottom": ds.bounds.bottom,
                "right": ds.bounds.right,
                "top": ds.bounds.top
            })
    except Exception as e:
        rows.append({
            "source_file": fp.name,
            "clipped_file": out_fp.name,
            "year": year,
            "month": month,
            "status": f"failed: {repr(e)}"
        })

df_clip = pd.DataFrame(rows).sort_values(["year", "month"]).reset_index(drop=True)
clip_csv = OUT_DIR / "GOSIF_CornBeltClip_inventory_2017_2021.csv"
df_clip.to_csv(clip_csv, index=False)

print(df_clip.head())
print("Saved:", clip_csv)

# ============================================================
# Memory-optimized 0.25° grid panel builder
# One region at a time
# ============================================================

import re
import gc
import numpy as np
import pandas as pd
from pathlib import Path
import rasterio
from rasterio.windows import from_bounds
from rasterio.warp import reproject, Resampling

# -----------------------------
# Paths
# -----------------------------
BASE_DIR = Path("/content/drive/MyDrive/Crop_Remote_Sensing_US")
GEE_DIR = BASE_DIR / "GEE_CornBelt"
SIF_DIR = BASE_DIR / "SIF"
OUT_DIR = BASE_DIR / "_grid_panel_optimized"
OUT_DIR.mkdir(parents=True, exist_ok=True)

# -----------------------------
# Region: run ONE first
# -----------------------------
REGION = {
    "name": "HumidCore_IA_IL",
    "left": -94.0,
    "bottom": 40.0,
    "right": -89.0,
    "top": 43.5
}

YEARS = [2017, 2018, 2019, 2020, 2021]
MONTHS = list(range(1, 13))
CROP_FRAC_THRESHOLD = 0.30

# -----------------------------
# Helpers
# -----------------------------
def parse_year(name):
    m = re.search(r'(20\d{2})', name)
    return int(m.group(1)) if m else None

def parse_gosif_year_month(name):
    m = re.search(r'GOSIF_(20\d{2})\.M(0[1-9]|1[0-2])', name)
    if m:
        return int(m.group(1)), int(m.group(2))
    return None, None

def get_template(vod_fp, region):
    with rasterio.open(vod_fp) as ds:
        win = from_bounds(
            region["left"], region["bottom"],
            region["right"], region["top"],
            transform=ds.transform
        ).round_offsets().round_lengths()

        arr = ds.read(1, window=win, masked=True)
        transform = ds.window_transform(win)

        return {
            "window": win,
            "height": arr.shape[0],
            "width": arr.shape[1],
            "transform": transform,
            "crs": ds.crs
        }

def extract_subset(fp, band, window):
    with rasterio.open(fp) as ds:
        arr = ds.read(band, window=window, masked=True).astype("float64")
        return arr.filled(np.nan)

def reproject_full_to_template(src_fp, dst_shape, dst_transform, dst_crs, clean_sif=False):
    with rasterio.open(src_fp) as src:
        src_arr = src.read(1, masked=True).astype("float64").filled(np.nan)

        if clean_sif:
            src_arr[src_arr >= 32766] = np.nan
            src_arr[src_arr < -999] = np.nan

        dst = np.full(dst_shape, np.nan, dtype="float64")

        reproject(
            source=src_arr,
            destination=dst,
            src_transform=src.transform,
            src_crs=src.crs,
            dst_transform=dst_transform,
            dst_crs=dst_crs,
            src_nodata=np.nan,
            dst_nodata=np.nan,
            resampling=Resampling.average
        )

    return dst

def build_lonlat(height, width, transform):
    rows, cols = np.meshgrid(np.arange(height), np.arange(width), indexing="ij")
    xs = transform.c + (cols + 0.5) * transform.a
    ys = transform.f + (rows + 0.5) * transform.e
    return xs, ys

# -----------------------------
# File maps
# -----------------------------
vod_files = {parse_year(fp.name): fp for fp in sorted(GEE_DIR.glob("CornBelt_VOD_monthly_*.tif"))}
sm_files = {parse_year(fp.name): fp for fp in sorted(GEE_DIR.glob("CornBelt_SM_monthly_*.tif"))}
clim_files = {parse_year(fp.name): fp for fp in sorted(GEE_DIR.glob("CornBelt_Climate_monthly_*.tif"))}
crop_files = {parse_year(fp.name): fp for fp in sorted(GEE_DIR.glob("CornBelt_CropMask_*.tif"))}

sif_map = {}
for fp in sorted(SIF_DIR.rglob("GOSIF_*.tif")):
    if fp.is_file():
        y, m = parse_gosif_year_month(fp.name)
        if y is not None:
            sif_map[(y, m)] = fp

print("VOD years:", sorted(vod_files))
print("SM years:", sorted(sm_files))
print("Climate years:", sorted(clim_files))
print("Crop years:", sorted(crop_files))
print("SIF entries:", len(sif_map))

# -----------------------------
# 1. Template grid
# -----------------------------
template = get_template(vod_files[2017], REGION)
h, w = template["height"], template["width"]
win = template["window"]
transform = template["transform"]
crs = template["crs"]

print("Template shape:", h, w)

# -----------------------------
# 2. Build static valid grid mask
#    Use crop fraction from a representative year first
#    (you can later switch to year-specific crop fraction)
# -----------------------------
crop_ref_fp = crop_files[2019]

crop_frac_ref = reproject_full_to_template(
    src_fp=crop_ref_fp,
    dst_shape=(h, w),
    dst_transform=transform,
    dst_crs=crs,
    clean_sif=False
)

valid_mask = np.isfinite(crop_frac_ref) & (crop_frac_ref >= CROP_FRAC_THRESHOLD)
valid_idx = np.flatnonzero(valid_mask.ravel())

print("Total grid cells:", h * w)
print("Crop-dominant valid cells:", len(valid_idx))

# optional lon/lat only for valid cells
lon2d, lat2d = build_lonlat(h, w, transform)
lon_valid = lon2d.ravel()[valid_idx]
lat_valid = lat2d.ravel()[valid_idx]
crop_valid_ref = crop_frac_ref.ravel()[valid_idx]

# save grid reference
df_grid_ref = pd.DataFrame({
    "grid_idx": valid_idx.astype(int),
    "lon": lon_valid,
    "lat": lat_valid,
    "crop_fraction_ref2019": crop_valid_ref
})
grid_ref_csv = OUT_DIR / f"{REGION['name']}_grid_reference.csv"
df_grid_ref.to_csv(grid_ref_csv, index=False)
print("Saved grid reference:", grid_ref_csv)

# -----------------------------
# 3. Stream through year-month
# -----------------------------
rows_out = []

for year in YEARS:
    print(f"\nProcessing year {year} ...")

    vod_fp = vod_files[year]
    sm_fp = sm_files[year]
    clim_fp = clim_files[year]

    # year-specific crop fraction if you want dynamic crop mask
    crop_frac_year = reproject_full_to_template(
        src_fp=crop_files[year],
        dst_shape=(h, w),
        dst_transform=transform,
        dst_crs=crs,
        clean_sif=False
    )
    crop_year_valid = crop_frac_year.ravel()[valid_idx]

    for month in MONTHS:
        # --- read only needed bands
        vod_arr = extract_subset(vod_fp, month, win)
        sm_arr = extract_subset(sm_fp, month, win)

        b_precip = (month - 1) * 3 + 1
        b_t2m    = (month - 1) * 3 + 2
        b_vpd    = (month - 1) * 3 + 3

        precip_arr = extract_subset(clim_fp, b_precip, win) * 1000.0
        t2m_arr    = extract_subset(clim_fp, b_t2m, win)
        vpd_arr    = extract_subset(clim_fp, b_vpd, win)

        # --- SIF reproject to template
        sif_fp = sif_map.get((year, month), None)
        if sif_fp is not None:
            sif_arr = reproject_full_to_template(
                src_fp=sif_fp,
                dst_shape=(h, w),
                dst_transform=transform,
                dst_crs=crs,
                clean_sif=True
            ) * 0.0001
        else:
            sif_arr = np.full((h, w), np.nan, dtype="float64")

        # --- flatten only valid cells
        vod_v = vod_arr.ravel()[valid_idx]
        sm_v = sm_arr.ravel()[valid_idx]
        precip_v = precip_arr.ravel()[valid_idx]
        t2m_v = t2m_arr.ravel()[valid_idx]
        vpd_v = vpd_arr.ravel()[valid_idx]
        sif_v = sif_arr.ravel()[valid_idx]

        # keep rows where at least core variables exist
        keep = np.isfinite(vod_v) | np.isfinite(sm_v) | np.isfinite(sif_v)

        df_m = pd.DataFrame({
            "region": REGION["name"],
            "year": year,
            "month": month,
            "grid_idx": valid_idx[keep].astype(int),
            "lon": lon_valid[keep],
            "lat": lat_valid[keep],
            "crop_fraction": crop_year_valid[keep],
            "vod": vod_v[keep],
            "sm": sm_v[keep],
            "precip_mm": precip_v[keep],
            "t2m_c": t2m_v[keep],
            "vpd": vpd_v[keep],
            "sif": sif_v[keep]
        })

        rows_out.append(df_m)

        # release
        del vod_arr, sm_arr, precip_arr, t2m_arr, vpd_arr, sif_arr
        del vod_v, sm_v, precip_v, t2m_v, vpd_v, sif_v, df_m
        gc.collect()

# -----------------------------
# 4. Save final panel
# -----------------------------
panel = pd.concat(rows_out, ignore_index=True)
panel["date"] = pd.to_datetime(dict(year=panel["year"], month=panel["month"], day=1))

out_csv = OUT_DIR / f"{REGION['name']}_grid_panel_2017_2021.csv"
panel.to_csv(out_csv, index=False)

print("\nFinal panel shape:", panel.shape)
print(panel.head())
print("Saved:", out_csv)

# Optional lightweight summary
summary = panel.describe(include="all")
summary.to_csv(OUT_DIR / f"{REGION['name']}_grid_panel_summary.csv")
print("Saved summary.")

# ============================================================
# Event-centered composite plot (top-journal style, Scheme C)
# line + 95% CI + faint bootstrap trajectories
# ============================================================

import os
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

# ============================================================
# 0. Paths
# ============================================================
PANEL_PATH = "/content/drive/MyDrive/Crop_Remote_Sensing_US/_whole_area_analysis/step6_struct_func_decoupling/panel_with_DI_step2.csv"
OUT_DIR = "/content/drive/MyDrive/Crop_Remote_Sensing_US/_whole_area_analysis/event_composite_topjournal"
os.makedirs(OUT_DIR, exist_ok=True)

# ============================================================
# 1. Load data
# ============================================================
df = pd.read_csv(PANEL_PATH)

df["time"] = pd.to_datetime(
    df["year"].astype(int).astype(str) + "-" +
    df["month"].astype(int).astype(str).str.zfill(2) + "-01"
)

df["VPD"] = df["vpd"]
df["SM"] = df["sm"]
df["SSRD"] = df["ssrd"]
df["T2M"] = df["t2m"]
df["PRECIP"] = df["precip"]

# ============================================================
# 2. Basic cleaning
# ============================================================
grow = df[df["month"].isin([4, 5, 6, 7, 8, 9, 10])].copy()

for c in ["DI", "z_vod", "z_sif", "VPD", "SM"]:
    grow = grow[grow[c].notna()]
    grow = grow[grow[c] != 0]

# 可选：去掉极端异常值
grow = grow[(grow["DI"] > -5) & (grow["DI"] < 5)].copy()

# ============================================================
# 3. Define events
# ============================================================
EVENT_THRESHOLD = -1.0
WINDOW = 4   # -4 to +4

grow["event"] = (grow["DI"] < EVENT_THRESHOLD).astype(int)

# ============================================================
# 4. Extract event-centered panel
# ============================================================
records = []

for gid, g in grow.groupby("grid_id"):
    g = g.sort_values("time").reset_index(drop=True)
    event_idx = g.index[g["event"] == 1].tolist()

    for idx in event_idx:
        for rel in range(-WINDOW, WINDOW + 1):
            j = idx + rel
            if 0 <= j < len(g):
                row = {
                    "grid_id": gid,
                    "event_time": g.loc[idx, "time"],
                    "rel_month": rel
                }
                ok = True
                for v in ["DI", "z_vod", "z_sif", "VPD", "SM"]:
                    val = g.loc[j, v]
                    if pd.isna(val) or val == 0:
                        ok = False
                        break
                    row[v] = val
                if ok:
                    records.append(row)

event_panel = pd.DataFrame(records)
assert len(event_panel) > 0, "No event-centered records extracted."

event_panel.to_csv(os.path.join(OUT_DIR, "event_centered_panel_window4.csv"), index=False)

# 简单统计
n_events = event_panel[["grid_id", "event_time"]].drop_duplicates().shape[0]
n_grids = event_panel["grid_id"].nunique()

print("Event-centered rows:", len(event_panel))
print("Unique events:", n_events)
print("Unique grids :", n_grids)

# ============================================================
# 5. Bootstrap composite (cluster bootstrap by grid)
# ============================================================
rng = np.random.default_rng(42)
n_boot = 300

grid_ids = event_panel["grid_id"].unique()
boot_list = []

for b in range(n_boot):
    sampled_grids = rng.choice(grid_ids, size=len(grid_ids), replace=True)
    boot_df = pd.concat(
        [event_panel[event_panel["grid_id"] == gid] for gid in sampled_grids],
        ignore_index=True
    )

    comp = (
        boot_df.groupby("rel_month")[["DI", "z_vod", "z_sif", "VPD", "SM"]]
        .median()
        .reset_index()
    )
    comp["boot"] = b
    boot_list.append(comp)

boot_panel = pd.concat(boot_list, ignore_index=True)
boot_panel.to_csv(os.path.join(OUT_DIR, "event_centered_bootstrap_panel.csv"), index=False)

# observed median
obs = (
    event_panel.groupby("rel_month")[["DI", "z_vod", "z_sif", "VPD", "SM"]]
    .median()
    .reset_index()
)

# summarize CI
def summarize_ci(var):
    out = (
        boot_panel.groupby("rel_month")[var]
        .agg(
            median_boot="median",
            ci_low=lambda x: np.nanpercentile(x, 2.5),
            ci_high=lambda x: np.nanpercentile(x, 97.5)
        )
        .reset_index()
    )
    out = out.rename(columns={
        "median_boot": f"{var}_boot",
        "ci_low": f"{var}_low",
        "ci_high": f"{var}_high"
    })
    return out

sum_di  = summarize_ci("DI")
sum_vod = summarize_ci("z_vod")
sum_sif = summarize_ci("z_sif")
sum_vpd = summarize_ci("VPD")
sum_sm  = summarize_ci("SM")

plot_top = obs.merge(sum_di, on="rel_month").merge(sum_vod, on="rel_month").merge(sum_sif, on="rel_month")
plot_bot = obs.merge(sum_vpd, on="rel_month").merge(sum_sm, on="rel_month")

# ============================================================
# 6. Style
# ============================================================
plt.rcParams.update({
    "figure.dpi": 180,
    "savefig.dpi": 300,
    "font.size": 11,
    "axes.titlesize": 15,
    "axes.labelsize": 12,
