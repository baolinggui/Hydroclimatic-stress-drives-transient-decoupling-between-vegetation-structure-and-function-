def build_month_coverage(df, dataset_name):
    """
    构建 year-month 覆盖表
    """
    sub = df.copy()
    sub = sub[sub["year"].notna()].copy()
    sub["year"] = sub["year"].astype(int)

    if "month" not in sub.columns:
        sub["month"] = np.nan

    out = []
    years = sorted(sub["year"].dropna().unique().tolist())
    for y in years:
        row = {"dataset_type": dataset_name, "year": y}
        for m in range(1, 13):
            exists = (((sub["year"] == y) & (sub["month"] == m)).any())
            row[f"m{m:02d}"] = int(exists)
        row["n_months"] = sum(row[f"m{m:02d}"] for m in range(1, 13))
        out.append(row)
    return pd.DataFrame(out)

# GEE 按类型分别看
