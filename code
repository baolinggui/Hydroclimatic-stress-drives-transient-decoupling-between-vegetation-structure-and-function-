import numpy as np
import pandas as pd
from pathlib import Path
import rasterio

BASE_DIR = Path("/content/drive/MyDrive/Crop_Remote_Sensing_US")
GEE_DIR = BASE_DIR / "GEE_CornBelt"
OUT_DIR = BASE_DIR / "_analysis_step2_fixSM"
OUT_DIR.mkdir(parents=True, exist_ok=True)

CSV_CLEAN = GEE_DIR / "CornBelt_monthly_county_2017_2021_clean.csv"

# -----------------------------
# 1. Helper
# -----------------------------
def parse_year_from_name(name):
    import re
    m = re.search(r'(20\d{2})', name)
    return int(m.group(1)) if m else None

def extract_monthly_means_from_stack_nan_safe(fp, value_name):
    year = parse_year_from_name(fp.name)
    rows = []

    with rasterio.open(fp) as ds:
        descs = list(ds.descriptions) if ds.descriptions is not None else []

        for b in range(1, ds.count + 1):
            arr = ds.read(b, masked=True).astype("float64")

            # 关键修复：把 masked 和内部 nan 都统一成 np.nan
            arr_np = arr.filled(np.nan)

            val = float(np.nanmean(arr_np)) if np.isfinite(arr_np).any() else np.nan

            rows.append({
                "year": year,
                "month": b,   # annual monthly stack: band 1..12 -> month 1..12
                value_name: val,
                "source_tif": str(fp),
                "band": b,
                "band_desc": descs[b - 1] if len(descs) >= b else None,
                "band_min": float(np.nanmin(arr_np)) if np.isfinite(arr_np).any() else np.nan,
                "band_max": float(np.nanmax(arr_np)) if np.isfinite(arr_np).any() else np.nan,
                "n_valid": int(np.isfinite(arr_np).sum())
            })

    return pd.DataFrame(rows)

# -----------------------------
# 2. Recover SM again
# -----------------------------
sm_tifs = sorted(GEE_DIR.glob("CornBelt_SM_monthly_*.tif"))
print("SM tif files found:", len(sm_tifs))

sm_parts = []
for fp in sm_tifs:
    df_part = extract_monthly_means_from_stack_nan_safe(fp, "sm_roi_mean_from_tif")
    sm_parts.append(df_part)

df_sm = pd.concat(sm_parts, ignore_index=True).sort_values(["year", "month"]).reset_index(drop=True)

print("\nRecovered SM preview:")
print(df_sm.head(15))

sm_csv = OUT_DIR / "CornBelt_monthly_sm_from_tif_2017_2021_fixed.csv"
df_sm.to_csv(sm_csv, index=False)
print("\nSaved:", sm_csv)

# -----------------------------
# 3. Read county clean CSV
# -----------------------------
df_county = pd.read_csv(CSV_CLEAN)

keep_cols = [
    "GEOID", "NAME", "STATEFP",
    "year", "month",
    "vod", "precip", "t2m_c", "vpd"
]
keep_cols = [c for c in keep_cols if c in df_county.columns]
df_county = df_county[keep_cols].copy()

for c in ["year", "month", "vod", "precip", "t2m_c", "vpd"]:
    if c in df_county.columns:
        df_county[c] = pd.to_numeric(df_county[c], errors="coerce")

df_county["date"] = pd.to_datetime(
    dict(year=df_county["year"].astype(int), month=df_county["month"].astype(int), day=1),
    errors="coerce"
)

# -----------------------------
# 4. Build regional monthly table and merge SM
# -----------------------------
vars_avail = [c for c in ["precip", "vod", "t2m_c", "vpd"] if c in df_county.columns]

df_regional = (
    df_county.groupby(["year", "month", "date"])[vars_avail]
             .mean()
             .reset_index()
             .sort_values(["year", "month"])
)

df_regional = df_regional.merge(
    df_sm[["year", "month", "sm_roi_mean_from_tif"]],
    on=["year", "month"],
    how="left"
)

if "precip" in df_regional.columns:
    df_regional["precip_mm"] = df_regional["precip"] * 1000.0

regional_csv = OUT_DIR / "CornBelt_regional_monthly_mean_2017_2021_withSM_fixed.csv"
df_regional.to_csv(regional_csv, index=False)

print("\nRegional monthly table with SM preview:")
print(df_regional.head(12))
print("\nSaved:", regional_csv)

# -----------------------------
# 5. Update county table
# -----------------------------
df_county_with_sm = df_county.merge(
    df_sm[["year", "month", "sm_roi_mean_from_tif"]],
    on=["year", "month"],
    how="left"
)

county_with_sm_csv = GEE_DIR / "CornBelt_monthly_county_2017_2021_clean_plusSMroi_fixed.csv"
df_county_with_sm.to_csv(county_with_sm_csv, index=False)

print("\nCounty table + ROI mean SM preview:")
print(df_county_with_sm.head())
print("\nSaved:", county_with_sm_csv)

# -----------------------------
# 6. Quick plot
# -----------------------------
import matplotlib.pyplot as plt

plot_cols = [c for c in ["precip_mm", "sm_roi_mean_from_tif", "vod", "t2m_c", "vpd"] if c in df_regional.columns]

for var in plot_cols:
    plt.figure(figsize=(10, 4))
    plt.plot(df_regional["date"], df_regional[var], marker="o")
    plt.title(f"Corn Belt monthly mean: {var}")
    plt.xlabel("Date")
    plt.ylabel(var)
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    plt.savefig(OUT_DIR / f"timeseries_{var}.png", dpi=220)
    plt.show()

print("\nAll SM-fixed outputs saved in:", OUT_DIR)

from pathlib import Path
import re
import pandas as pd
import rasterio

SIF_DIR = Path("/content/drive/MyDrive/Crop_Remote_Sensing_US/SIF")
OUT_DIR = Path("/content/drive/MyDrive/Crop_Remote_Sensing_US/_analysis_step2_fixSIF")
OUT_DIR.mkdir(parents=True, exist_ok=True)

def parse_gosif_year_month_from_path(path_str):
    # 支持从完整路径里找 GOSIF_2017.M01 这种模式
    m = re.search(r'GOSIF_(20\d{2})\.M(0[1-9]|1[0-2])', path_str)
    if m:
        return int(m.group(1)), int(m.group(2))
    return None, None

candidate_exts = {".tif", ".tiff", ".img", ".bil", ".nc", ".hdf"}

rows = []
for p in SIF_DIR.rglob("*"):
    if p.is_file() and p.suffix.lower() in candidate_exts:
        try:
            with rasterio.open(p) as ds:
                year, month = parse_gosif_year_month_from_path(str(p))
                rows.append({
                    "filepath": str(p),
                    "filename": p.name,
                    "year": year,
                    "month": month,
                    "count": ds.count,
                    "width": ds.width,
                    "height": ds.height,
                    "crs": str(ds.crs),
                    "left": ds.bounds.left,
                    "bottom": ds.bounds.bottom,
                    "right": ds.bounds.right,
                    "top": ds.bounds.top,
