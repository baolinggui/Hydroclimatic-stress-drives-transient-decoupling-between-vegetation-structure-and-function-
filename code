def list_files_recursive(root: Path, exts=None):
    """
    递归列出文件。exts 例如 ['.tif', '.csv']
    """
    files = []
    for p in root.rglob("*"):
        if p.is_file():
            if exts is None:
                files.append(p)
            else:
                if p.suffix.lower() in [e.lower() for e in exts]:
                    files.append(p)
    return sorted(files)

def extract_year_month_from_name(name: str):
    """
    尝试从文件名中提取 year / month
    支持：
    - 2017
    - 2017_01
    - 2017-01
    - 201701
    返回 (year, month)；若 month 不存在则为 None
    """
    # 先找 YYYY_MM 或 YYYY-MM
    m = re.search(r'(?<!\d)(20\d{2})[_-](0[1-9]|1[0-2])(?!\d)', name)
    if m:
        return int(m.group(1)), int(m.group(2))

    # 再找 YYYYMM
    m = re.search(r'(?<!\d)(20\d{2})(0[1-9]|1[0-2])(?!\d)', name)
    if m:
        return int(m.group(1)), int(m.group(2))

    # 只找年份
    m = re.search(r'(?<!\d)(20\d{2})(?!\d)', name)
    if m:
        return int(m.group(1)), None

    return None, None

def infer_dataset_type(name: str):
    """
    根据文件名粗略判断数据类型
    """
    low = name.lower()
    if "vod" in low:
        return "VOD"
    if re.search(r'(^|[_\-])sm([_\-]|$)', low) or "soil" in low:
        return "SM"
    if "climate" in low:
        return "Climate"
    if "cropmask" in low or "crop_mask" in low:
        return "CropMask"
    if "sif" in low:
        return "SIF"
    if low.endswith(".csv"):
        return "CSV"
    return "Unknown"

def safe_open_raster_meta(fp: Path):
    """
    安全读取 tif 基本信息
    """
    try:
        with rasterio.open(fp) as ds:
            meta = {
                "width": ds.width,
                "height": ds.height,
                "count": ds.count,
                "crs": str(ds.crs) if ds.crs else None,
                "dtype": ds.dtypes[0] if ds.count > 0 else None,
                "nodata": ds.nodata,
                "bounds_left": ds.bounds.left,
                "bounds_bottom": ds.bounds.bottom,
                "bounds_right": ds.bounds.right,
                "bounds_top": ds.bounds.top,
                "res_x": ds.res[0],
                "res_y": ds.res[1],
                "driver": ds.driver,
            }
            # band descriptions
            descs = list(ds.descriptions) if ds.descriptions is not None else []
            meta["band_descriptions"] = json.dumps(descs, ensure_ascii=False)
        return meta
    except Exception as e:
        return {
            "width": None,
            "height": None,
            "count": None,
            "crs": None,
            "dtype": None,
            "nodata": None,
            "bounds_left": None,
            "bounds_bottom": None,
            "bounds_right": None,
            "bounds_top": None,
            "res_x": None,
            "res_y": None,
            "driver": None,
            "band_descriptions": None,
            "read_error": str(e)
        }

