# ============================================================
# Smoothed DI–VPD curves under different SM regimes
# with bootstrap 95% confidence intervals
# ============================================================

import os
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from statsmodels.nonparametric.smoothers_lowess import lowess

# ============================================================
# 0. Paths
# ============================================================
PANEL_PATH = "/content/drive/MyDrive/Crop_Remote_Sensing_US/_whole_area_analysis/step6_struct_func_decoupling/panel_with_DI_step2.csv"
OUT_DIR = "/content/drive/MyDrive/Crop_Remote_Sensing_US/_whole_area_analysis/fig_DI_VPD_SM_smooth"
os.makedirs(OUT_DIR, exist_ok=True)

# ============================================================
# 1. Load and preprocess
# ============================================================
df = pd.read_csv(PANEL_PATH)

df["VPD"] = df["vpd"]
df["SM"] = df["sm"]

# 只保留生长季
df = df[df["month"].isin([4, 5, 6, 7, 8, 9, 10])].copy()

# 去掉缺失 / 0 / 极端异常值
for c in ["DI", "VPD", "SM"]:
    df = df[df[c].notna()]
    df = df[df[c] != 0]

df = df[(df["DI"] > -5) & (df["DI"] < 5)].copy()

print("Rows after cleaning:", len(df))
print("Unique grids:", df["grid_id"].nunique())

# ============================================================
# 2. Define soil-moisture regimes
# ============================================================
df["SM_regime"] = pd.qcut(df["SM"], q=3, labels=["Dry", "Normal", "Wet"])

print("\nCounts by SM regime:")
print(df["SM_regime"].value_counts())

# ============================================================
# 3. Bin VPD within each SM regime
#    fewer bins = smoother and more stable
# ============================================================
N_BINS = 10

dfs = []
for regime, sub in df.groupby("SM_regime", observed=False):
    sub = sub.copy()
    # 在每个 regime 内部分箱
    sub["VPD_bin"] = pd.qcut(sub["VPD"], q=N_BINS, duplicates="drop")
    dfs.append(sub)

df_bin = pd.concat(dfs, ignore_index=True)

# 每个 bin 的中位 VPD 作为横坐标
bin_mid = (
    df_bin.groupby(["SM_regime", "VPD_bin"], observed=False)["VPD"]
    .median()
    .reset_index()
    .rename(columns={"VPD": "VPD_mid"})
)

obs = (
    df_bin.groupby(["SM_regime", "VPD_bin"], observed=False)["DI"]
    .median()
    .reset_index()
    .rename(columns={"DI": "DI_med"})
)

obs = obs.merge(bin_mid, on=["SM_regime", "VPD_bin"], how="left")

print("\nObserved binned medians:")
print(obs.head())

# ============================================================
# 4. Cluster bootstrap by grid_id
#    保持面板结构，不按单行抽样
# ============================================================
rng = np.random.default_rng(42)
n_boot = 300

grid_ids = df_bin["grid_id"].unique()
boot_rows = []

for b in range(n_boot):
    sampled_grids = rng.choice(grid_ids, size=len(grid_ids), replace=True)

    # 这里直接拼接抽到的格网数据
    boot_df = pd.concat(
        [df_bin[df_bin["grid_id"] == gid] for gid in sampled_grids],
        ignore_index=True
    )

    # 重新在每个 regime 内做分箱（保持和原分析一致）
    tmp_list = []
    for regime, sub in boot_df.groupby("SM_regime", observed=False):
        sub = sub.copy()
        if len(sub) < N_BINS:
            continue
        sub["VPD_bin"] = pd.qcut(sub["VPD"], q=N_BINS, duplicates="drop")
        tmp_list.append(sub)

    if len(tmp_list) == 0:
        continue

    boot_df2 = pd.concat(tmp_list, ignore_index=True)

    # 算每个 regime × bin 的中位 VPD 和中位 DI
    boot_mid = (
        boot_df2.groupby(["SM_regime", "VPD_bin"], observed=False)["VPD"]
        .median()
        .reset_index()
        .rename(columns={"VPD": "VPD_mid"})
    )

    boot_med = (
        boot_df2.groupby(["SM_regime", "VPD_bin"], observed=False)["DI"]
        .median()
        .reset_index()
        .rename(columns={"DI": "DI_med"})
    )

    boot_out = boot_med.merge(boot_mid, on=["SM_regime", "VPD_bin"], how="left")
    boot_out["boot"] = b
    boot_rows.append(boot_out)

boot = pd.concat(boot_rows, ignore_index=True)

print("\nBootstrap rows:", len(boot))

# ============================================================
# 5. Summarize bootstrap CI
# ============================================================
ci = (
    boot.groupby(["SM_regime", "VPD_bin"], observed=False)["DI_med"]
    .agg(
        median_boot="median",
        ci_low=lambda x: np.nanpercentile(x, 2.5),
        ci_high=lambda x: np.nanpercentile(x, 97.5)
    )
    .reset_index()
)

plot_df = obs.merge(ci, on=["SM_regime", "VPD_bin"], how="left")
plot_df = plot_df.sort_values(["SM_regime", "VPD_mid"]).reset_index(drop=True)

plot_df.to_csv(os.path.join(OUT_DIR, "DI_VPD_SM_bootstrap_summary.csv"), index=False)

print("\nPlot summary:")
print(plot_df.head())

# ============================================================
# 6. LOWESS smoothing helper
# ============================================================
def smooth_curve(x, y, frac=0.5):
    """
    LOWESS smoothing.
    frac 越大越平滑；0.45~0.6 一般比较合适
    """
    valid = ~(np.isnan(x) | np.isnan(y))
    x = np.asarray(x)[valid]
    y = np.asarray(y)[valid]

    if len(x) < 4:
        return x, y

    sm = lowess(y, x, frac=frac, return_sorted=True)
    return sm[:, 0], sm[:, 1]

# ============================================================
# 7. Plot smoothed curves + CI bands
# ============================================================
plt.figure(figsize=(9, 5.5))

colors = {
    "Dry": "#6C9DC6",
    "Normal": "#E39B6D",
    "Wet": "#88B96A"
}

for regime in ["Dry", "Normal", "Wet"]:
    sub = plot_df[plot_df["SM_regime"] == regime].sort_values("VPD_mid")

    x = sub["VPD_mid"].values
    y = sub["DI_med"].values
    ylow = sub["ci_low"].values
    yhigh = sub["ci_high"].values

    # 平滑中位数和CI上下边界
    xs, ys = smooth_curve(x, y, frac=0.5)
    x1, y1 = smooth_curve(x, ylow, frac=0.5)
    x2, y2 = smooth_curve(x, yhigh, frac=0.5)

    # 统一 x 网格，方便 fill_between
    x_common = np.linspace(np.nanmin(x), np.nanmax(x), 200)
    ys_i = np.interp(x_common, xs, ys)
    y1_i = np.interp(x_common, x1, y1)
    y2_i = np.interp(x_common, x2, y2)

    # CI 阴影
    plt.fill_between(
        x_common, y1_i, y2_i,
        color=colors[regime], alpha=0.18, linewidth=0
    )

    # 平滑主曲线
    plt.plot(
        x_common, ys_i,
        color=colors[regime], linewidth=2.6,
        label=regime
    )

    # 可选：保留原始分箱点，淡一点
    plt.scatter(
        x, y,
        color=colors[regime], s=28, alpha=0.55, zorder=3
    )

plt.axhline(0, linestyle="--", color="black", linewidth=1.2)
plt.xlabel("VPD")
plt.ylabel("Median DI")
plt.title("Smoothed response of structural–functional decoupling to atmospheric dryness")
plt.legend(title="SM regime", frameon=False)
plt.tight_layout()
plt.savefig(os.path.join(OUT_DIR, "DI_VPD_SM_smooth_CI.png"), dpi=300)
plt.show()

