# -----------------------------
ax = axes[0]

# faint bootstrap trajectories
for b in range(min(n_boot, 120)):  # 不用全画，避免太密
    sub = boot_panel[boot_panel["boot"] == b].sort_values("rel_month")
    ax.plot(sub["rel_month"], sub["z_vod"], color=COL["vod"], alpha=0.03, linewidth=1)
    ax.plot(sub["rel_month"], sub["z_sif"], color=COL["sif"], alpha=0.03, linewidth=1)
